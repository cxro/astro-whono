---
import type { AdminRouteId } from '../../lib/admin-console/routes';
import AdminNav from './AdminNav.astro';

const {
  currentRoute,
  title,
  subtitle,
  modeLabel,
  showNav = true
} = Astro.props as {
  currentRoute: AdminRouteId;
  title: string;
  subtitle: string;
  modeLabel: string;
  showNav?: boolean;
};
---

<section class="admin-console admin-console--shell">
  <header class="page-header page-header--admin">
    <div class="admin-heading">
      <div class="admin-heading__copy">
        <h1 class="page-title">{title}</h1>
        <span class="page-subtitle">{subtitle}</span>
      </div>
      <span class="admin-mode-chip">{modeLabel}</span>
    </div>
    <slot name="status" />
  </header>

  {showNav ? <AdminNav currentRoute={currentRoute} /> : null}

  <div class="admin-shell">
    <slot />
  </div>
</section>
