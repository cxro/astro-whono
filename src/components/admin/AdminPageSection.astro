---
import { ADMIN_ARTICLE_META_DATE_LABEL_MAX_LENGTH } from '../../lib/admin-console/shared';

interface Props {
  pageTitleMaxLength: number;
  pageSubtitleMaxLength: number;
  memoTitlePlaceholder?: string;
  memoSubtitlePlaceholder?: string;
}

const {
  pageTitleMaxLength,
  pageSubtitleMaxLength,
  memoTitlePlaceholder = '',
  memoSubtitlePlaceholder = ''
} = Astro.props;
---

<fieldset class="admin-group">
  <legend class="admin-group__legend">
    <span class="admin-group__legend-zh">Inner Page Settings</span>
    <span class="admin-group__legend-sep" aria-hidden="true">·</span>
    <span class="admin-group__legend-en">Inner pages</span>
  </legend>
  <div class="admin-grid">
    <label class="admin-field">
      <span class="admin-label">
        <span class="admin-label__main">
          <code>/essay/</code> Main <span class="admin-label__pipe" aria-hidden="true">|</span> Subtitle
        </span>
        <span class="admin-label__hint">(Dynamic count / Fixed output for RSS)</span>
      </span>
      <span class="admin-title-pair" role="group" aria-label="/essay/ Main and Subtitle">
        <input
          id="page-essay-title"
          class="admin-title-pair__input admin-title-pair__input--title"
          type="text"
          maxlength={pageTitleMaxLength}
          autocomplete="off"
          placeholder="Essay"
          aria-label="/essay/ Main Title"
        />
        <span class="admin-title-pair__sep" aria-hidden="true">|</span>
        <input
          id="page-essay-subtitle"
          class="admin-title-pair__input admin-title-pair__input--subtitle"
          type="text"
          maxlength={pageSubtitleMaxLength}
          autocomplete="off"
          placeholder="Essays and Notes"
          aria-label="/essay/ Subtitle"
        />
      </span>
    </label>
    <label class="admin-field">
      <span class="admin-label">
        <span class="admin-label__main">
          <code>/bits/</code> Main <span class="admin-label__pipe" aria-hidden="true">|</span> Subtitle
        </span>
      </span>
      <span class="admin-title-pair" role="group" aria-label="/bits/ Main and Subtitle">
        <input
          id="page-bits-title"
          class="admin-title-pair__input admin-title-pair__input--title"
          type="text"
          maxlength={pageTitleMaxLength}
          autocomplete="off"
          placeholder="Bits"
          aria-label="/bits/ Main Title"
        />
        <span class="admin-title-pair__sep" aria-hidden="true">|</span>
        <input
          id="page-bits-subtitle"
          class="admin-title-pair__input admin-title-pair__input--subtitle"
          type="text"
          maxlength={pageSubtitleMaxLength}
          autocomplete="off"
          placeholder="Life is more than long stories"
          aria-label="/bits/ Subtitle"
        />
      </span>
    </label>
    <label class="admin-field admin-field--full admin-field--memo">
      <span class="admin-label">
        <span class="admin-label__main">
          <code>/memo/</code> Main <span class="admin-label__pipe" aria-hidden="true">|</span> Subtitle
        </span>
        <span class="admin-label__hint">(Overrides corresponding fields if filled, otherwise uses src/content/memo/index.md)</span>
      </span>
      <span class="admin-title-pair" role="group" aria-label="/memo/ Main and Subtitle">
        <input
          id="page-memo-title"
          class="admin-title-pair__input admin-title-pair__input--title"
          type="text"
          maxlength={pageTitleMaxLength}
          autocomplete="off"
          placeholder={memoTitlePlaceholder || undefined}
          aria-label="/memo/ Main Title"
        />
        <span class="admin-title-pair__sep" aria-hidden="true">|</span>
        <input
          id="page-memo-subtitle"
          class="admin-title-pair__input admin-title-pair__input--subtitle"
          type="text"
          maxlength={pageSubtitleMaxLength}
          autocomplete="off"
          placeholder={memoSubtitlePlaceholder || undefined}
          aria-label="/memo/ Subtitle"
        />
      </span>
    </label>
    <label class="admin-field">
      <span class="admin-label">
        <span class="admin-label__main">
          <code>/archive/</code> Main <span class="admin-label__pipe" aria-hidden="true">|</span> Subtitle
        </span>
        <span class="admin-label__hint">(Dynamic count / Fixed output for RSS)</span>
      </span>
      <span class="admin-title-pair" role="group" aria-label="/archive/ Main and Subtitle">
        <input
          id="page-archive-title"
          class="admin-title-pair__input admin-title-pair__input--title"
          type="text"
          maxlength={pageTitleMaxLength}
          autocomplete="off"
          placeholder="Archive"
          aria-label="/archive/ Main Title"
        />
        <span class="admin-title-pair__sep" aria-hidden="true">|</span>
        <input
          id="page-archive-subtitle"
          class="admin-title-pair__input admin-title-pair__input--subtitle"
          type="text"
          maxlength={pageSubtitleMaxLength}
          autocomplete="off"
          placeholder="Archive directory grouped by year"
          aria-label="/archive/ Subtitle"
        />
      </span>
    </label>
    <label class="admin-field">
      <span class="admin-label">
        <span class="admin-label__main">
          <code>/about/</code> Main <span class="admin-label__pipe" aria-hidden="true">|</span> Subtitle
        </span>
      </span>
      <span class="admin-title-pair" role="group" aria-label="/about/ Main and Subtitle">
        <input
          id="page-about-title"
          class="admin-title-pair__input admin-title-pair__input--title"
          type="text"
          maxlength={pageTitleMaxLength}
          autocomplete="off"
          placeholder="About"
          aria-label="/about/ Main Title"
        />
        <span class="admin-title-pair__sep" aria-hidden="true">|</span>
        <input
          id="page-about-subtitle"
          class="admin-title-pair__input admin-title-pair__input--subtitle"
          type="text"
          maxlength={pageSubtitleMaxLength}
          autocomplete="off"
          aria-label="/about/ Subtitle"
        />
      </span>
    </label>
  </div>

  <div class="admin-subgroup">
    <p class="admin-subtitle">
      <span class="admin-subtitle__main">Article Meta Information</span>
      <span class="admin-subtitle__hint">(Word count/reading time only on detail page, hidden on mobile)</span>
    </p>
    <div class="admin-toggle-row-group admin-toggle-row-group--article-meta">
      <div class="admin-toggle-row admin-toggle-row--with-inline-field">
        <label class="admin-toggle-row admin-toggle-row--compact" for="ui-article-meta-show-date">
          <input id="ui-article-meta-show-date" type="checkbox" />
          <span>Show publish date</span>
        </label>
        <span class="admin-toggle-row__sep" aria-hidden="true">|</span>
        <label class="admin-inline-field" for="ui-article-meta-date-label">
          <span class="admin-inline-field__label">Prefix:</span>
          <input
            id="ui-article-meta-date-label"
            class="admin-inline-field__input"
            type="text"
            maxlength={ADMIN_ARTICLE_META_DATE_LABEL_MAX_LENGTH}
            autocomplete="off"
            placeholder="Published on:"
          />
        </label>
      </div>
      <label class="admin-toggle-row">
        <input id="ui-article-meta-show-tags" type="checkbox" />
        <span>Show tags</span>
      </label>
      <label class="admin-toggle-row">
        <input id="ui-article-meta-show-word-count" type="checkbox" />
        <span>Show word count</span>
      </label>
      <label class="admin-toggle-row">
        <input id="ui-article-meta-show-reading-time" type="checkbox" />
        <span>Show reading time</span>
      </label>
    </div>
    <p class="admin-help admin-help--article-meta-preview">
      Preview: <code id="article-meta-preview-value" class="admin-help__preview-value">{'Published on: 2026-03-18 · #Astro\u00A0\u00A0#Writing · Total 2,416 words · About 6 minutes'}</code>
    </p>
  </div>

  <div class="admin-subgroup">
    <p class="admin-subtitle">
      <span class="admin-subtitle__main">/bits/ Page Default Author</span>
    </p>
    <div class="admin-grid">
      <label class="admin-field">
        <span class="admin-label">
          <span class="admin-label__main">Default Author Name</span>
        </span>
        <input id="page-bits-author-name" type="text" autocomplete="off" />
      </label>
      <label class="admin-field">
        <span class="admin-label">
          <span class="admin-label__main">Default Avatar</span>
          <span class="admin-label__hint">(Relative path)</span>
        </span>
        <input id="page-bits-author-avatar" type="text" autocomplete="off" />
      </label>
    </div>
  </div>
</fieldset>
