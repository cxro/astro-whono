---
import AdminLayout from './AdminLayout.astro';
import AdminImagePicker from './AdminImagePicker.astro';
import AdminReadonlyNotice from './AdminReadonlyNotice.astro';
import AdminShell from './AdminShell.astro';
import {
  getAdminContentEntryListHref,
  type AdminContentCollectionKey
} from '../../lib/admin-console/content';
import {
  ADMIN_CONTENT_DELETE_API_PATH,
  ADMIN_CONTENT_ENTRY_API_PATH,
  ADMIN_CONTENT_EXPORT_API_PATH,
  ADMIN_IMAGE_LIST_API_PATH,
  ADMIN_IMAGE_META_API_PATH,
  ADMIN_IMAGE_UPLOAD_API_PATH,
  ADMIN_PREVIEW_API_PATH
} from '../../lib/admin-console/admin-api-paths';
import { getThemeSettings } from '../../lib/theme-settings';
import { createWithBase } from '../../utils/format';
import {
  buildBitsEditorIslandProps,
  buildEssayEditorIslandProps,
  loadAdminContentEditDevState
} from './admin-content-edit-dev-state';

type Props = {
  collection: AdminContentCollectionKey;
  entryId: string;
  initialArticleInfoOpen?: boolean;
};

const { collection, entryId, initialArticleInfoOpen = false } = Astro.props;

const isDev = import.meta.env.DEV;
const shouldShowContentConsole = isDev;
const base = import.meta.env.BASE_URL ?? '/';
const withBase = createWithBase(base);
const { settings } = getThemeSettings();
const bitsDefaultAuthor = settings.page.bits.defaultAuthor;
const { default: adminShellStylesHref } = await import('../../styles/components/admin/shell.css?url');
const contentEditDevState = shouldShowContentConsole
  ? await loadAdminContentEditDevState({
      collection,
      entryId,
      adminShellStylesHref,
      withBase
    })
  : null;
const selectedEntryEditorPayload = contentEditDevState?.payload ?? null;
const essayEditorPayload = selectedEntryEditorPayload?.writable && selectedEntryEditorPayload.collection === 'essay'
  ? selectedEntryEditorPayload
  : null;
const bitsEditorPayload = selectedEntryEditorPayload?.writable && selectedEntryEditorPayload.collection === 'bits'
  ? selectedEntryEditorPayload
  : null;
const memoEditorPayload = selectedEntryEditorPayload?.collection === 'memo'
  ? selectedEntryEditorPayload
  : null;
// Keep Svelte islands behind DEV-only dynamic imports; static imports leak
// editor chunks into the production build.
let EssayEditorIsland: any = null;
let BitsEditorIsland: any = null;
if (import.meta.env.DEV && essayEditorPayload) {
  EssayEditorIsland = (await import('./editor/EssayEditorIsland.astro')).default;
}
if (import.meta.env.DEV && bitsEditorPayload) {
  BitsEditorIsland = (await import('./editor/BitsEditorIsland.astro')).default;
}
const adminStylesHref = contentEditDevState?.stylesHref ?? adminShellStylesHref;
const collectionHref = withBase(getAdminContentEntryListHref(collection));
const shouldUseSvelteEssayEditor = Boolean(EssayEditorIsland);
const shouldUseBitsEditor = Boolean(BitsEditorIsland);
const shouldUseEditorPageLayout = shouldUseSvelteEssayEditor || shouldUseBitsEditor;
const contentEditorBodyClass = shouldUseEditorPageLayout ? 'admin-page--content-editor' : undefined;
const editorEndpoints = {
  endpoint: withBase(ADMIN_CONTENT_ENTRY_API_PATH),
  exportEndpoint: withBase(ADMIN_CONTENT_EXPORT_API_PATH),
  deleteEndpoint: withBase(ADMIN_CONTENT_DELETE_API_PATH),
  previewEndpoint: withBase(ADMIN_PREVIEW_API_PATH),
  imageUploadEndpoint: withBase(ADMIN_IMAGE_UPLOAD_API_PATH)
};
const adminImageListEndpoint = withBase(ADMIN_IMAGE_LIST_API_PATH);
const adminImageMetaEndpoint = withBase(ADMIN_IMAGE_META_API_PATH);
const essayEditorIslandProps = essayEditorPayload && contentEditDevState
  ? buildEssayEditorIslandProps({
      payload: essayEditorPayload,
      endpoints: editorEndpoints,
      returnHref: withBase('/admin/content/'),
      essayOutlineItems: contentEditDevState.essayOutlineItems,
      initialArticleInfoOpen
    })
  : null;
const bitsEditorIslandProps = bitsEditorPayload && contentEditDevState
  ? buildBitsEditorIslandProps({
      payload: bitsEditorPayload,
      endpoints: editorEndpoints,
      returnHref: collectionHref,
      defaultAuthor: bitsDefaultAuthor,
      bitsOutlineItems: contentEditDevState.bitsOutlineItems
    })
  : null;
const contentConsoleSubtitle = selectedEntryEditorPayload
  ? `${selectedEntryEditorPayload.collection} · ${
      selectedEntryEditorPayload.collection === 'essay'
        ? '内容编辑'
        : selectedEntryEditorPayload.writable
          ? '内容编辑'
          : '只读详情'
    }`
  : '内容编辑';
const editTitle = selectedEntryEditorPayload
  ? (
      selectedEntryEditorPayload.values.title
      || ('description' in selectedEntryEditorPayload.values ? selectedEntryEditorPayload.values.description : '')
      || selectedEntryEditorPayload.entryId
    )
  : entryId;
const getReadonlyValue = (value: string): string => value || '(未设置)';
const memoReadonlyRows = memoEditorPayload
  ? [
      { label: 'memo.title', value: getReadonlyValue(memoEditorPayload.values.title) },
      { label: 'memo.subtitle', value: getReadonlyValue(memoEditorPayload.values.subtitle) },
      { label: 'memo.date', value: getReadonlyValue(memoEditorPayload.values.date) },
      { label: 'memo.slug', value: getReadonlyValue(memoEditorPayload.values.slug) },
      { label: 'memo.draft', value: memoEditorPayload.values.draft ? 'true' : 'false' }
    ]
  : [];
---

<AdminLayout
  title={shouldUseEditorPageLayout ? editTitle : 'Content Console'}
  stylesHref={adminStylesHref}
  bodyClass={contentEditorBodyClass}
  adminSidebarScope="page"
>
  <AdminShell
    currentRoute="content"
    title="Content Console"
    subtitle={contentConsoleSubtitle}
    showHeader={!shouldUseEditorPageLayout}
    showNav={false}
  >
    {
      shouldShowContentConsole && selectedEntryEditorPayload ? (
        <section
          class:list={[
            'admin-content-console',
            'admin-content-edit-page',
            shouldUseSvelteEssayEditor && 'admin-content-edit-page--essay',
            shouldUseBitsEditor && 'admin-content-edit-page--bits'
          ]}
        >
          <header class="admin-content-page-head">
            <div class="admin-content-page-head__copy">
              {
                shouldUseSvelteEssayEditor || shouldUseBitsEditor ? (
                  <div class="admin-content-title-row">
                    <h2 class="admin-content-heading">{editTitle}</h2>
                    {
                      shouldUseSvelteEssayEditor ? (
                        <button
                          class="admin-content-info-trigger"
                          type="button"
                          data-admin-article-info-trigger
                          aria-haspopup="dialog"
                          aria-controls="admin-editor-frontmatter-panel"
                          aria-expanded="false"
                        >
                          修改信息
                        </button>
                      ) : (
                        <button
                          class="admin-content-info-trigger"
                          type="button"
                          data-admin-bits-info-trigger
                          aria-haspopup="dialog"
                          aria-controls="admin-editor-frontmatter-panel"
                          aria-expanded="false"
                        >
                          修改信息
                        </button>
                      )
                    }
                  </div>
                ) : (
                  <>
                    <p class="admin-content-kicker">{selectedEntryEditorPayload.collection}</p>
                    <h2 class="admin-content-heading">{editTitle}</h2>
                  </>
                )
              }
              {
                !shouldUseEditorPageLayout ? (
                  <p class="admin-content-copy">
                    <code>{selectedEntryEditorPayload.relativePath}</code>
                  </p>
                ) : null
              }
            </div>
            <div
              class="admin-content-actions"
              data-admin-editor-page-actions-host={shouldUseEditorPageLayout ? true : undefined}
            >
              {
                shouldUseEditorPageLayout ? (
                  <a
                    class="admin-btn admin-btn--ghost admin-btn--compact"
                    href={shouldUseBitsEditor ? collectionHref : withBase('/admin/content/')}
                    data-admin-editor-page-actions-fallback
                  >
                    返回
                  </a>
                ) : (
                  <>
                    <a class="admin-btn admin-btn--ghost" href={collectionHref}>返回列表</a>
                    <a class="admin-btn admin-btn--ghost" href={withBase('/admin/content/')}>Content 总入口</a>
                  </>
                )
              }
            </div>
          </header>

          {
            EssayEditorIsland && essayEditorIslandProps ? (
              <article class="admin-content-editor admin-content-editor--svelte">
                <EssayEditorIsland {...essayEditorIslandProps} />
              </article>
            ) : BitsEditorIsland && bitsEditorIslandProps ? (
              <article class="admin-content-editor admin-content-editor--bits">
                <BitsEditorIsland {...bitsEditorIslandProps} />
              </article>
            ) : (
              <article class="admin-content-readonly">
                <div class="admin-content-section-head">
                  <div>
                    <p class="admin-content-kicker">Readonly</p>
                    <h3 class="admin-content-section-title">当前 collection 保持只读</h3>
                    <p class="admin-content-copy">{selectedEntryEditorPayload.readonlyReason}</p>
                  </div>
                </div>
                <dl class="admin-data-meta admin-content-detail-meta">
                  {
                    memoReadonlyRows.map((row) => (
                      <>
                        <dt class="admin-data-meta__label">{row.label}</dt>
                        <dd class="admin-data-meta__value">{row.value}</dd>
                      </>
                    ))
                  }
                </dl>
              </article>
            )
          }
        </section>
      ) : (
        <AdminReadonlyNotice>
          若需查看或编辑内容索引，请在本地运行 <code translate="no">npm run dev</code> 后从此入口进入。
        </AdminReadonlyNotice>
      )
    }
  </AdminShell>

  {
    shouldShowContentConsole && shouldUseBitsEditor ? (
      <AdminImagePicker listEndpoint={adminImageListEndpoint} metaEndpoint={adminImageMetaEndpoint} />
    ) : null
  }
</AdminLayout>
