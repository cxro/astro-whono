---
import Icon from '../Icon.astro';
import { ADMIN_SOCIAL_ORDER_MAX } from '../../lib/admin-console/shared';

interface Props {
  row: {
    id: 'github' | 'x' | 'email';
    label: string;
    orderInputId: string;
    inputId: string;
    inputType: 'url' | 'email';
    inputMode: 'url' | 'email';
    autoComplete: string;
    placeholder: string;
  };
}

const { row } = Astro.props;
const visibilityLabel = `Hide ${row.label}`;
const removeLabel = `${row.label} is a fixed item and cannot be removed`;
---

<article
  class="admin-social-row admin-social-row--preset"
  data-social-preset-row
  data-social-preset-id={row.id}
>
  <label class="admin-field admin-social-field admin-social-field--order">
    <span class="admin-social-cell-label">Position</span>
    <span class="admin-social-order-frame">
      <span class="admin-social-order-frame__mark" aria-hidden="true">[</span>
      <input
        id={row.orderInputId}
        data-social-preset-field="order"
        type="number"
        min="1"
        max={String(ADMIN_SOCIAL_ORDER_MAX)}
        step="1"
        inputmode="numeric"
        aria-label={`${row.label} Position Order`}
      />
      <span class="admin-social-order-frame__mark" aria-hidden="true">]</span>
    </span>
  </label>

  <div
    class="admin-field admin-social-field admin-social-field--platform admin-social-field--static"
  >
    <span class="admin-social-cell-label">Platform</span>
    <input
      class="admin-social-static-input"
      name={`site-social-${row.id}-platform-display`}
      type="text"
      value={row.label}
      readonly
      tabindex="-1"
    />
  </div>

  <div
    class="admin-field admin-social-field admin-social-field--id admin-social-field--static"
  >
    <span class="admin-social-cell-label">Link ID</span>
    <input
      class="admin-social-static-input admin-social-static-input--code"
      name={`site-social-${row.id}-id-display`}
      type="text"
      value={row.id}
      readonly
      tabindex="-1"
    />
  </div>

  <div
    class="admin-social-field admin-social-field--icon admin-social-field--static"
  >
    <span class="admin-social-cell-label">Icon</span>
    <div class="admin-social-icon-preview">
      <span class="admin-social-icon-only">
        <Icon name={row.id} class="admin-social-icon-only__icon" size={16} />
      </span>
    </div>
  </div>

  <label class="admin-field admin-social-field admin-social-field--href">
    <span class="admin-social-cell-label"
      >{row.id === 'email' ? 'Email Address' : 'Link URL'}</span
    >
    <input
      id={row.inputId}
      data-social-preset-field="href"
      type={row.inputType}
      inputmode={row.inputMode}
      autocomplete={row.autoComplete}
      placeholder={row.placeholder}
    />
  </label>

  <div
    class="admin-field admin-social-field admin-social-field--actions admin-social-field--static"
  >
    <span class="admin-social-cell-label">Actions</span>
    <div class="admin-social-row-actions">
      <button
        class="admin-social-action"
        type="button"
        data-social-preset-action="toggle-visible"
        aria-pressed="true"
        aria-label={visibilityLabel}
        title={visibilityLabel}
      >
        <Icon name="eye" class="admin-social-action__icon" size={15} />
        <span class="sr-only">{visibilityLabel}</span>
      </button>
      <button
        class="admin-social-action admin-social-action--disabled"
        type="button"
        data-social-preset-action="remove"
        aria-label={removeLabel}
        title={removeLabel}
        disabled
      >
        <Icon name="trash" class="admin-social-action__icon" size={15} />
        <span class="sr-only">{removeLabel}</span>
      </button>
    </div>
  </div>
</article>
