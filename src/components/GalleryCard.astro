---
import { render } from 'astro:content';
import { type GalleryEntry, getGalleryAnchorId } from '../lib/gallery';
import { createWithBase, formatDateTime } from '../utils/format';

const { bit, prioritizeLeadMedia = false } = Astro.props;
const bitEntry = bit as GalleryEntry;

const tags = bit.data.tags ?? [];
const placeTag = tags.find((t: string) => t.toLowerCase().startsWith('loc:')) ?? '';
const placeText = placeTag ? placeTag.slice(4).trim() : '';
const normalTags = tags.filter((t: string) => !t.toLowerCase().startsWith('loc:'));
const base = import.meta.env.BASE_URL ?? '/';
const withBase = createWithBase(base);
type GalleryImage = { src: string; width: number; height: number; alt?: string };
const images = (bit.data.images ?? []) as GalleryImage[];
const imageItems = images.map((image) => ({ ...image, src: withBase(image.src) }));
const maxVisible = 4;
const visibleImages = imageItems.slice(0, maxVisible);
const totalImages = imageItems.length;
const wideIndex = totalImages > 1 && totalImages <= maxVisible && totalImages % 2 === 1 ? 0 : -1;
const getImageLoading = (prioritize: boolean) => (prioritize ? 'eager' : 'lazy');
const getImageFetchPriority = (prioritize: boolean) => (prioritize ? 'high' : undefined);
const { Content } = bit.body ? await render(bit) : { Content: null };
const singleImage = imageItems.length === 1 ? imageItems[0] : null;
---

<article
  class="gallery-card"
  id={getGalleryAnchorId(bitEntry.id)}
  data-gallery
  data-gallery-key={bitEntry.id}
  data-slug={bitEntry.data.slug ?? bitEntry.id}
>
  {singleImage ? (
    <div class="gallery-media gallery-media--single">
      <button
        type="button"
        class="gallery-media-item gallery-media-item--single"
        data-gallery-image-button
        data-gallery-image-index="0"
        aria-label="View image"
      >
        <img
          src={singleImage.src}
          alt={singleImage.alt ?? ''}
          width={singleImage.width}
          height={singleImage.height}
          loading={getImageLoading(prioritizeLeadMedia)}
          fetchpriority={getImageFetchPriority(prioritizeLeadMedia)}
        />
      </button>
    </div>
  ) : imageItems.length > 1 ? (
    <div class="gallery-media gallery-media--grid">
      <div class="gallery-media-grid">
        {visibleImages.map((image, index) => {
          const isMore = index === maxVisible - 1 && imageItems.length > maxVisible;
          return (
            <button
              type="button"
              class={`gallery-media-item${index === wideIndex ? ' gallery-media-item--wide' : ''}${isMore ? ' gallery-media-item--more' : ''}`}
              data-gallery-image-button
              data-gallery-image-index={index}
              aria-label={isMore ? `View all images (${imageItems.length} total)` : `Image ${index + 1}`}
            >
              <img
                src={image.src}
                alt={image.alt ?? ''}
                width={image.width}
                height={image.height}
                loading={getImageLoading(prioritizeLeadMedia && index === 0)}
                fetchpriority={getImageFetchPriority(prioritizeLeadMedia && index === 0)}
              />
              {isMore ? (
                <span class="gallery-media-more" aria-hidden="true">
                  + {imageItems.length - maxVisible}
                </span>
              ) : null}
            </button>
          );
        })}
      </div>
    </div>
  ) : null}

  {imageItems.length ? (
    <div hidden aria-hidden="true">
      {imageItems.map((image) => (
        <span
          data-gallery-image-item
          data-gallery-image-src={image.src}
          data-gallery-image-alt={image.alt ?? ''}
          data-gallery-image-width={image.width}
          data-gallery-image-height={image.height}
        ></span>
      ))}
    </div>
  ) : null}

  {bit.body || placeText || normalTags.length ? (
    <div class="gallery-meta">
      {Content ? (
        <div class="gallery-caption">
          <Content />
        </div>
      ) : null}
      <div class="gallery-info">
        {placeText ? (
          <span class="gallery-tag gallery-tag--place">
            <span aria-hidden="true">??</span>
            <span>{placeText}</span>
          </span>
        ) : null}
        {normalTags.length ? (
          <span class="gallery-tag gallery-tag--normal">
            {normalTags.map((tag: string) => (
              <span class="gallery-tag-token">#{tag}</span>
            ))}
          </span>
        ) : null}
        <span class="gallery-date">{formatDateTime(bit.data.date)}</span>
      </div>
    </div>
  ) : (
    <div class="gallery-meta">
      <span class="gallery-date">{formatDateTime(bit.data.date)}</span>
    </div>
  )}
</article>

<style>
  .gallery-card { padding: 0; border: 0; border-radius: 10px; margin: 16px 0; background: var(--panel); scroll-margin-top: 24px; overflow: hidden; }
  @supports (background: color-mix(in srgb, #000 50%, #fff 50%)) { .gallery-card { background: color-mix(in srgb, var(--panel) 38%, var(--bg)); } }
  .gallery-media { margin: 0; border-radius: 0; overflow: hidden; border: 0; }
  .gallery-media img { display: block; width: 100%; height: auto; }
  .gallery-media--grid { width: 100%; overflow: visible; }
  .gallery-media-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 0; width: 100%; }
  .gallery-media-item { position: relative; overflow: hidden; aspect-ratio: 4 / 3; border: 0; background: transparent; padding: 0; width: 100%; display: block; text-align: left; cursor: pointer; appearance: none; }
  .gallery-media-item--more::after { content: ""; position: absolute; inset: 0; background: rgba(0, 0, 0, 0.4); pointer-events: none; }
  .gallery-media-item--wide { grid-column: 1 / -1; aspect-ratio: 21 / 9; }
  .gallery-media-item--single { aspect-ratio: auto; }
  .gallery-media-item--single > img { width: 100%; height: auto; }
  .gallery-media--grid .gallery-media-item > img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.2s ease; }
  .gallery-media-item:hover > img { transform: scale(1.02); }
  .gallery-media-more { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; font-size: 24px; font-weight: 600; color: #fff; pointer-events: none; z-index: 1; }
  .gallery-media-item:focus-visible { outline: 2px solid var(--muted); outline-offset: 3px; }
  .gallery-meta { padding: 14px 18px; }
  .gallery-caption { font-size: 14px; line-height: 1.6; margin-bottom: 10px; }
  .gallery-info { display: flex; flex-wrap: wrap; align-items: center; gap: 12px; font-size: 12px; color: var(--faint); }
  .gallery-tag { display: inline-flex; align-items: center; gap: 6px; }
  .gallery-tag-token { display: inline-block; }
  .gallery-tag--normal { color: #d34; }
  .gallery-tag--place { color: var(--muted); }
  .gallery-date { margin-left: auto; }
  @media (max-width: 640px) {
    .gallery-media-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 0; }
    .gallery-media-item { aspect-ratio: 1 / 1; }
    .gallery-media-item--wide { grid-column: auto; aspect-ratio: 1 / 1; }
    .gallery-info { gap: 8px; }
    .gallery-date { margin-left: 0; width: 100%; margin-top: 4px; }
  }
</style>
