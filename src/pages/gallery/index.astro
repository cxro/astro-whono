  items={items}
  resultCount={totalCount}
  currentPage={currentPage}
  totalPages={totalPages}
  yearOptions={yearOptions}
  prevPath={null}
  nextPath={totalPages > 1 ? getBitsPagePath(currentPage + 1) : null}
  activeNavId="gallery"
/>
