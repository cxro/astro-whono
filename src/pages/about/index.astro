---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/Icon.astro';
import '../../styles/about.css';
import { getThemeSettings, type SiteSocialIconKey } from '../../lib/theme-settings';
const { settings } = getThemeSettings();
const resolvedSocialItems = settings.site.socialLinks.resolvedSocialItems.filter((item) => item.visible);
const aboutTitle = settings.page.about.title || 'About';
const aboutSubtitle = settings.page.about.subtitle;

type SocialActionItem = {
  key: string;
  href: string;
  label: string;
  title: string;
  icon: SiteSocialIconKey;
};

type ContactItem = {
  key: string;
  href: string;
  icon: SiteSocialIconKey;
  text: string;
};

const formatExternalLabel = (href: string): string => {
  try {
    const parsed = new URL(href);
    const path = parsed.pathname.replace(/^\/+|\/+$/g, '');
    return path || parsed.hostname;
  } catch {
    return href;
  }
};

const socialItems: SocialActionItem[] = [
  ...resolvedSocialItems.map((item) => ({
    key: item.id,
    href: item.href,
    label: item.label,
    title: item.label,
    icon: item.iconKey
  }))
];

const contactItems: ContactItem[] = [
  ...resolvedSocialItems.map((item) => ({
    key: item.id,
    href: item.href,
    icon: item.iconKey,
    text: item.id === 'email' ? item.href.replace(/^mailto:/i, '') : formatExternalLabel(item.href)
  }))
];
---

<BaseLayout title={aboutTitle} bodyClass="about-page">
  <div class="page-header page-header--about">
    <div class="page-heading">
      <h1 class="page-title">{aboutTitle}</h1>
      {aboutSubtitle ? <span class="page-subtitle">{aboutSubtitle}</span> : null}
    </div>
    {
      socialItems.length ? (
        <div class="page-actions">
          {socialItems.map((item) => (
            <a class="icon-link" href={item.href} aria-label={item.title} title={item.title}>
              <Icon name={item.icon} class="icon" />
            </a>
          ))}
        </div>
      ) : null
    }
  </div>
  <p class="about-intro-line">
    Whono is a minimalist two-column writing theme based on Astro: clean, fast, and designed for reading.<br />
    Content is written in Markdown, supporting dark mode, code highlighting, RSS, and immersive reading. It is suitable as a starting point for personal writing and lightweight content publishing.<br />
    The theme is maintained as open-source. If you have suggestions for improvement or want to help perfect it together, you are welcome to create an <a href="https://github.com/cxro/astro-whono/issues">Issue</a> to discuss.
  </p>
  <h2 class="section-title about-section-title">Category Guide</h2>
  <div class="site-guide">
    <article class="site-guide-item">
      <div class="site-guide-head">
        <h3 class="site-guide-title">Essays</h3>
        <span class="site-guide-link">/essay/</span>
      </div>
      <p class="site-guide-desc">Article feed list (including unarchived content).</p>
    </article>
    <article class="site-guide-item">
      <div class="site-guide-head">
        <h3 class="site-guide-title">Bits</h3>
        <span class="site-guide-link">/bits/</span>
      </div>
      <p class="site-guide-desc">Short content dynamic feed, fragmented thoughts (supports multiple images).</p>
    </article>
    <article class="site-guide-item">
      <div class="site-guide-head">
        <h3 class="site-guide-title">Memos</h3>
        <span class="site-guide-link">/memo/</span>
      </div>
      <p class="site-guide-desc">Organize some moments and memories worth keeping.</p>
    </article>
    <article class="site-guide-item">
      <div class="site-guide-head">
        <h3 class="site-guide-title">Archives</h3>
        <span class="site-guide-link">/archive/</span>
      </div>
      <p class="site-guide-desc">Archived directory grouped by year.</p>
    </article>
  </div>

  <h2 class="section-title about-section-title">Tech Stack</h2>
  <div class="tech-stack">
    <section class="tech-group">
      <div class="tech-group-title">Build & Rendering</div>
      <ul class="tech-list">
        <li class="tech-item">
          <div class="tech-item-head">
            <span class="tech-item-title">Astro / Vite</span>
          </div>
          <div class="tech-item-desc">Content site and build</div>
        </li>
        <li class="tech-item">
          <div class="tech-item-head">
            <span class="tech-item-title">CSS / Typography</span>
          </div>
          <div class="tech-item-desc">Typography and reading experience</div>
        </li>
      </ul>
    </section>
    <section class="tech-group">
      <div class="tech-group-title">Languages & Tools</div>
      <ul class="tech-list">
        <li class="tech-item">
          <div class="tech-item-head">
            <span class="tech-item-title">TypeScript</span>
          </div>
          <div class="tech-item-desc">Type constraints and script support</div>
        </li>
        <li class="tech-item">
          <div class="tech-item-head">
            <span class="tech-item-title">Markdown</span>
          </div>
          <div class="tech-item-desc">Content writing and publishing workflow</div>
        </li>
      </ul>
    </section>
    
  </div>

  <h2 class="section-title about-section-title">Frequently Asked Questions</h2>
  <section class="qa-list" aria-label="Frequently Asked Questions">
    <details class="qa-item">
      <summary class="qa-question"><span class="qa-icon" aria-hidden="true">Q</span>Why do I see a 'SITE_URL is not set' warning after deployment?</summary>
      <p class="qa-answer">Because the production domain is not configured. When not set, a placeholder domain is used, and <code>canonical</code>/<code>og:url</code>/<code>sitemap</code>/<code>robots</code> will be incomplete. Add <code>SITE_URL=https://yourdomain</code> to the environment variables in your deployment platform and rebuild.</p>
    </details>
    <details class="qa-item">
      <summary class="qa-question"><span class="qa-icon" aria-hidden="true">Q</span>Why don't some articles appear in the archives?</summary>
      <p class="qa-answer">The archive filters out articles with <code>archive: false</code>. They are still "published and accessible", but will not appear in the archive list and archive RSS (useful for a few pieces of content you don't want indexed in the directory).</p>
    </details>
    <details class="qa-item">
      <summary class="qa-question"><span class="qa-icon" aria-hidden="true">Q</span>Why does opening an article in /essay/ redirect to /archive/.../?</summary>
      <p class="qa-answer">The project unifies article details under <code>/archive/{'{'}slug{'}'}/</code>. <code>/essay/</code> primarily serves as the entry point for the article feed list. This avoids duplicate detail routes and facilitates long-term maintenance.</p>
    </details>
    <details class="qa-item">
      <summary class="qa-question"><span class="qa-icon" aria-hidden="true">Q</span>How can I report issues or participate in improvements?</summary>
      <p class="qa-answer">Directly create an <a href="https://github.com/cxro/astro-whono/issues">Issue</a> in the repository, or submit a <a href="https://github.com/cxro/astro-whono/pulls">Pull Request</a>.</p>
    </details>
  </section>

  {
    contactItems.length ? (
      <>
        <h2 class="section-title about-section-title">Contact & Subscribe</h2>
        <section class="contact-block" aria-label="Contact Information">
          <p class="contact-note">If you have questions, suggestions, or want to subscribe to updates, you can reach out through the following methods.</p>
          <ul class="contact-list">
            {contactItems.map((item) => (
              <li>
                <span class="contact-link-head" aria-hidden="true">
                  <Icon name={item.icon} class="contact-icon" />
                </span>
                <a href={item.href}>{item.text}</a>
              </li>
            ))}
          </ul>
        </section>
      </>
    ) : null
  }

</BaseLayout>