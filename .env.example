# Production site URL (no trailing slash)
# Required for sitemap, RSS, canonical URLs, and Open Graph tags.
SITE_URL=https://your-domain.com

# Node environment (optional)
# 'production' triggers static build output and stricter warnings.
# NODE_ENV=production

# Internal test overrides (developers only)
# ASTRO_WHONO_INTERNAL_TEST_SETTINGS=1
# ASTRO_WHONO_INTERNAL_TEST_SETTINGS_DIR=/path/to/fixture/settings
